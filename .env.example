# Google Cloud — required
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# Authentication — choose ONE of the two options below:
#
# Option A: service account key file (downloaded from GCP IAM)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
#
# Option B: run `gcloud auth application-default login` in your terminal
#           and leave GOOGLE_APPLICATION_CREDENTIALS unset.

# eBay API — only needed for ebay_auth.py and scrape_listing_details.py
EBAY_CLIENT_ID=your_app_id_here
EBAY_CLIENT_SECRET=your_cert_id_here
